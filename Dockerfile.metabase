FROM metabase/metabase:v0.63.1.4

ENV MB_JETTY_PORT=10000
ENV JAVA_TOOL_OPTIONS="-Xmx300m -XX:+UseSerialGC"
ENV MB_JETTY_MAXTHREADS=20
ENV MB_JETTY_MINTHREADS=2
ENV MB_DB_CONNECTION_POOL_MAX_SIZE=3
ENV MB_ANON_TRACKING_ENABLED=false
ENV MB_SEND_ANONYMOUS_USAGE_STATS=false
ENV MB_CHECK_FOR_UPDATES=false

EXPOSE 10000
