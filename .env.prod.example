# Production deployment uchun namuna.
# Serverda bundan .env.prod nusxa oling va parollarni kuchli qiymatlarga almashtiring.

POSTGRES_DB=uyjoy_olx
POSTGRES_USER=uyjoy
POSTGRES_PASSWORD=change_this_strong_postgres_password

PGADMIN_DEFAULT_EMAIL=admin@uyjoy.local
PGADMIN_DEFAULT_PASSWORD=change_this_strong_pgadmin_password

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_strong_dashboard_password
BACKUP_RETENTION_DAYS=14

OLX_BASE_URL=https://www.olx.uz
OLX_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) UyJoyETL/0.1
OLX_REQUEST_TIMEOUT_SECONDS=30
OLX_REQUEST_DELAY_SECONDS=1.5
OLX_MAX_RETRIES=3
OLX_CATEGORY_PATHS=nedvizhimost/kvartiry/prodazha,nedvizhimost/kvartiry/arenda-dolgosrochnaya,nedvizhimost/doma/prodazha,nedvizhimost/doma/arenda-dolgosrochnaya,nedvizhimost/zemlja/prodazha,nedvizhimost/zemlja/arenda,nedvizhimost/posutochno_pochasovo/kvartira,nedvizhimost/posutochno_pochasovo/dachi
OLX_MAX_PAGES_PER_CATEGORY=1
OLX_FETCH_DETAILS=false
